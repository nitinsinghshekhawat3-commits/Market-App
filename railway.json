{
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm ci --only=production --no-cache && npm install --no-cache"
  },
  "deploy": {
    "startCommand": "node server.cjs",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 600,
    "healthcheckInterval": 10,
    "restartPolicyType": "ON_FAILURE"
  }
}